{
  "expo": {
    "name": "GateSync",
    "slug": "gatesync-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gatesync.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.gatesync.mobile",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-notifications",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow GateSync guard devices to scan visitor QR passes and capture photos."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow GateSync to use the microphone for guard voice entry.",
          "speechRecognitionPermission": "Allow GateSync to convert guard speech to text for visitor names."
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow GateSync to capture visitor photos and attach complaint images."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow GateSync to use Face ID to unlock your session on this device."
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "https://api.gatesync.in",
      "socketUrl": "https://api.gatesync.in",
      "projectId": "c478175f-ff42-41fa-8b7d-428dde378c22",
      "eas": {
        "projectId": "c478175f-ff42-41fa-8b7d-428dde378c22"
      }
    }
  }
}
